    <!-- Help Screen -->
    <string name="help_title">Help &amp; Guide</string>
    <string name="help_intro">Welcome to Speaking Counter! Below is a guide on how to use the app features.</string>
    <string name="help_countdown_header">Count Down Mode</string>
    <string name="help_countdown_desc">Enter the hours, minutes, and seconds you wish to count down from. Tap Start to begin. The timer will count down to 00:00:00. When it finishes, a notification will display, an alert will show, and a speech announcement will play.</string>
    <string name="help_countup_header">Count Up Mode</string>
    <string name="help_countup_desc">This mode acts as a stopwatch starting from 00:00:00. Simply press Start to begin tracking your elapsed time.</string>
    <string name="help_speech_header">Speech Announcements</string>
    <string name="help_speech_desc">When \"Speak Aloud\" is checked, the app uses Android\'s TextToSpeech (TTS) engine to announce the remaining time (in Count Down) or elapsed time (in Count Up) at your selected interval.</string>
    <string name="help_intervals_header">How Intervals Work</string>
    <string name="help_intervals_desc">Choose a speaking interval from the dropdown spinner (e.g. \"Every 5 seconds\" or \"Every 10 seconds\"). The voice announcement will trigger exactly at those time milestones.</string>
    
